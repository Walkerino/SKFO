# SSH/deploy target
DEPLOY_HOST=203.0.113.10
DEPLOY_PORT=22
DEPLOY_USER=deploy
DEPLOY_PATH=/var/www/skfo

# Keep only N latest releases on server
DEPLOY_KEEP_RELEASES=5

# Composer on target host
DEPLOY_COMPOSER_BIN=/usr/bin/composer
SKIP_COMPOSER=0

# Retention for backup.sh
BACKUP_KEEP_DAYS=14

# ProcessWire runtime env (also used by backup.sh)
SKFO_DB_HOST=127.0.0.1
SKFO_DB_PORT=3306
SKFO_DB_NAME=skfo
SKFO_DB_USER=skfo
SKFO_DB_PASS=change_me

# Comma-separated allowed hosts (no protocol)
SKFO_HTTP_HOSTS=skfo.ru,www.skfo.ru

# Production-safe defaults
SKFO_DEBUG=0
SKFO_TIMEZONE=Europe/Moscow
SKFO_SESSION_NAME=pw353
SKFO_ADMIN_EMAIL=no-reply@skfo.ru
SKFO_FROM_EMAIL=no-reply@skfo.ru
SKFO_SUPPORT_EMAIL=support@skfo.ru

# Optional explicit SMTP configuration for auth emails
# If SKFO_SMTP_PROVIDER is set, host/port/secure can be inferred for supported providers.
SKFO_SMTP_PROVIDER=
SKFO_SMTP_HOST=
SKFO_SMTP_PORT=
SKFO_SMTP_SECURE=
SKFO_SMTP_USER=
SKFO_SMTP_PASS=
SKFO_SMTP_FROM_EMAIL=no-reply@skfo.ru
SKFO_SMTP_FROM_NAME=SKFO.RU

# Keep salts stable forever (required to keep logins/passwords valid)
SKFO_USER_AUTH_SALT=replace_with_current_value
SKFO_TABLE_SALT=replace_with_current_value
